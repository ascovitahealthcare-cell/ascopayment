# ══════════════════════════════════════════════════════
#  Ascovita Backend — Environment Variables Template
#  Copy this file to .env and fill in real values
#  NEVER commit your real .env file to GitHub
# ══════════════════════════════════════════════════════

# Cashfree Payment Gateway
# Get these from: https://merchant.cashfree.com/merchants/pg/dashboard
CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here

# Shiprocket Shipping
# Your Shiprocket login credentials
SHIPROCKET_EMAIL=your_shiprocket_email_here
SHIPROCKET_PASSWORD=your_shiprocket_password_here

# Server Port (Render sets this automatically, leave as 3000 for local)
PORT=3000
